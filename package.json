{
  "name": "coc-file-utils",
  "version": "0.0.7",
  "description": "The best way to create, copy, move, rename and delete files and folders (multiple files)",
  "author": "cyl <a1008611abcd@126.com>",
  "license": "MIT",
  "main": "lib/index.js",
  "keywords": [
    "coc.nvim"
  ],
  "engines": {
    "coc": "^0.0.82"
  },
  "scripts": {
    "watch": "node esbuild.mjs --watch",
    "build": "node esbuild.mjs",
    "prepare": "node esbuild.mjs"
  },
  "devDependencies": {
    "@types/which": "^3.0.4",
    "coc.nvim": "^0.0.83-next.18",
    "esbuild": "^0.19.8",
    "typescript": "^5.3.3"
  },
  "activationEvents": [
    "*"
  ],
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "coc-file-utils configuration",
      "properties": {
        "coc-file-utils.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable coc-file-utils extension"
        }
      }
    },
    "commands": [
      {
        "command": "coc-file-utils.delete",
        "title": "Delete File"
      },
      {
        "command": "coc-file-utils.rename",
        "title": "Rename File"
      }
    ]
  },
  "dependencies": {
    "minimatch": "^10.2.4",
    "which": "^6.0.1"
  }
}
